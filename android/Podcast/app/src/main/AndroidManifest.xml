<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- M2.F PoC: needs the network for future relay traffic; nothing else
         exotic. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- PR 13 — ExoPlayer foreground audio playback.

         The `mediaPlayback` foreground-service type was added in API 29 and
         is required by API 34 manifest validation when `MediaSessionService`
         runs in the foreground. `POST_NOTIFICATIONS` (Android 13+) lets
         media3 surface the media-style notification the system uses to keep
         the service alive. `WAKE_LOCK` keeps the CPU running while audio
         plays from the background — the rough analogue of iOS's
         `AVAudioSession` keeping the process audible. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ADR-0048 — NIP-55 external signer (Amber / Primal) package visibility.

         Android 11+ (API 30+) hides other installed packages from
         `PackageManager` unless declared here. Without these entries
         `detectInstalledSigners` (signing/ExternalSignerWire.kt) returns an
         empty list and the `nostrsigner:` Intent fails to resolve even when
         Amber is installed.

         Two forms are needed:
           * <intent> with the `nostrsigner`/`primal` schemes — so
             `queryIntentActivities`-based detection sees the signer.
           * explicit <package> — so `Intent.setPackage(...)` routing and the
             ContentResolver fast-path authority resolve to the real app. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="nostrsigner" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="primal" />
        </intent>
        <package android:name="com.greenart7c3.nostrsigner" />
        <package android:name="net.primal.android" />
    </queries>

    <application
        android:name=".PodcastApp"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- PR 13 — `MediaSessionService` host for ExoPlayer.

             `exported="true"` lets system clients (Bluetooth, Android Auto,
             Wear, lock screen, etc.) bind to the session; without it the
             session is invisible to the platform's media routing. The
             `MediaSessionService` intent-filter is the canonical hook
             media3 documents for service discovery.

             `foregroundServiceType="mediaPlayback"` matches the API 34
             requirement and the FOREGROUND_SERVICE_MEDIA_PLAYBACK
             permission declared above. -->
        <service
            android:name=".service.PodcastPlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>
    </application>

</manifest>
