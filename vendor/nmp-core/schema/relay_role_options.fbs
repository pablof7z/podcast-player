namespace nmp.kernel;

// Typed FlatBuffers wire for the kernel-owned `relay_role_options` snapshot
// projection (Tier-2: kernel built-in).
//
// The producer is `Kernel::snapshot_projections_with_publish_cluster` in
// `crates/nmp-core/src/kernel/update/projections.rs`, which inserts the
// `serde_json` serialisation of `crate::actor::relay_role_options()` (a
// `Vec<RelayRoleOption { value, label, tint: String, is_default: bool }>`)
// under the JSON key `"relay_role_options"`. That generic `Value` projection
// stays the source of truth (inserted unchanged); this buffer is emitted
// ALONGSIDE it in the `SnapshotFrame`'s `typed_projections` sidecar (ADR-0037)
// under the SAME key. A host with a `KRRO` decoder prefers this typed payload;
// an un-updated host falls back to the generic `Value` subtree. Purely
// additive (Wave C).
//
// Field-for-field mirror of `RelayRoleOption`. Order is preserved verbatim from
// the producer vector (the picker render order).
//
// Regenerate the checked-in Rust bindings only with the workspace FlatBuffers
// pin (25.12.19), enforced by ci/check-flatbuffers-version-pins.sh:
//   flatc --rust -o crates/nmp-core/src/kernel/typed_projections/generated \
//         crates/nmp-core/schema/relay_role_options.fbs

table RelayRoleOption {
  // Canonical role token written into `AppRelay.role` when picked.
  value:string;
  // Human-readable picker label.
  label:string;
  // Semantic tint token (`accent` / `info` / `success` / `neutral`).
  tint:string;
  // Whether this is the default role offered for a newly-added relay.
  is_default:bool;
}

table RelayRoleOptionsSnapshot {
  options:[RelayRoleOption];
}

file_identifier "KRRO";
root_type RelayRoleOptionsSnapshot;
