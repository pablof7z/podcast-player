include "profile_card.fbs";

namespace nmp.kernel;

// Typed FlatBuffers wire for the kernel-owned `profile` snapshot projection
// (Tier-2: kernel built-in).
//
// The producer is `Kernel::snapshot_projections_with_publish_cluster` in
// `crates/nmp-core/src/kernel/update/projections.rs`, which inserts the
// `serde_json` serialisation of `profile_card()` (a `ProfileCard` for the
// active account) under the JSON key `"profile"`. That generic `Value`
// projection stays the source of truth (inserted unchanged); this buffer is
// emitted ALONGSIDE it in the `SnapshotFrame`'s `typed_projections` sidecar
// (ADR-0037) under the SAME key. A host with a `KPRF` decoder prefers this
// typed payload; an un-updated host falls back to the generic `Value` subtree.
// Purely additive (Wave C).
//
// The `ProfileCard` row type is the SHARED definition `include`d from
// `profile_card.fbs` (see that file's header). `flatc` (no `--gen-all`) emits
// `ProfileCard` only into `profile_card_generated.{rs,swift}`; this schema's
// generated file merely references it — so the Swift `nmp_kernel_ProfileCard`
// struct is declared exactly once across the whole profile cluster.
//
// Regenerate the checked-in Rust bindings only with the workspace FlatBuffers
// pin (25.12.19), enforced by ci/check-flatbuffers-version-pins.sh:
//   flatc --rust -o crates/nmp-core/src/kernel/typed_projections/generated \
//         crates/nmp-core/schema/profile.fbs

table ProfileSnapshot {
  card:ProfileCard;
}

file_identifier "KPRF";
root_type ProfileSnapshot;
