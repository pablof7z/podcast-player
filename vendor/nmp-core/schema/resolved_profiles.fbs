include "profile_card.fbs";

namespace nmp.kernel;

// Typed FlatBuffers wire for the kernel-owned `resolved_profiles` snapshot
// projection (Tier-2: kernel built-in).
//
// The producer is `Kernel::snapshot_projections_with_publish_cluster` in
// `crates/nmp-core/src/kernel/update/projections.rs`, which inserts the
// `serde_json` serialisation of `resolved_profiles()` (a
// `BTreeMap<String, ProfileCard>`: the pre-merged pubkey -> profile card map
// every consumer reads — claimed_profiles > author_view.profile >
// mention_profiles precedence) under the JSON key `"resolved_profiles"`. That
// generic `Value` projection stays the source of truth (inserted unchanged);
// this buffer is emitted ALONGSIDE it in the `SnapshotFrame`'s
// `typed_projections` sidecar (ADR-0037) under the SAME key. A host with a
// `KRPR` decoder prefers this typed payload; an un-updated host falls back to
// the generic `Value` subtree. Purely additive (Wave C).
//
// FlatBuffers has no map type, so the `pubkey -> ProfileCard` map is flattened
// to a vector of `{key, value}` entries. The producer is a `BTreeMap`, so the
// entries are already sorted by key — preserved verbatim, matching the
// BTree-ordered serde JSON map.
//
// The `ProfileCard` row type is the SHARED definition `include`d from
// `profile_card.fbs` (see that file's header). `flatc` (no `--gen-all`) emits
// `ProfileCard` only into `profile_card_generated.{rs,swift}`; this schema's
// generated file merely references it — so the Swift `nmp_kernel_ProfileCard`
// struct is declared exactly once across the whole profile cluster.
//
// D0: a resolved-profile map is a generic pre-merged view of raw kind:0 profile
// fields — it carries no protocol-specific (NIP-NN) semantics, so it is
// kernel-owned and typed here. D6: the decoder returns `Err(String)` on
// malformed input, never panics.
//
// Regenerate the checked-in Rust bindings only with the workspace FlatBuffers
// pin (25.12.19), enforced by ci/check-flatbuffers-version-pins.sh:
//   flatc --rust -o crates/nmp-core/src/kernel/typed_projections/generated \
//         crates/nmp-core/schema/resolved_profiles.fbs

// One `pubkey -> ProfileCard` map entry. Entries are sorted by `key` (BTreeMap).
table ResolvedProfileEntry {
  // The map key — the resolved author's hex pubkey (matches `value.pubkey`).
  key:string;
  value:ProfileCard;
}

table ResolvedProfilesSnapshot {
  entries:[ResolvedProfileEntry];
}

file_identifier "KRPR";
root_type ResolvedProfilesSnapshot;
