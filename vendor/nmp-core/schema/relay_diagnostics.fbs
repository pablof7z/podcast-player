namespace nmp.kernel;

// Typed FlatBuffers wire for the kernel-owned `relay_diagnostics` snapshot
// projection (Tier-2: kernel built-in).
//
// The producer is `Kernel::snapshot_projections_with_publish_cluster` in
// `crates/nmp-core/src/kernel/update/projections.rs`, which inserts the
// `serde_json` serialisation of `relay_diagnostics_snapshot()` (a
// `RelayDiagnosticsSnapshot` — the pre-rolled diagnostics-screen view: one
// rolled-up row per relay URL plus the per-wire-subscription and logical-interest
// detail rows, every aggregate computed) under the JSON key `"relay_diagnostics"`.
// That generic `Value` projection stays the source of truth (inserted unchanged);
// this buffer is emitted ALONGSIDE it in the `SnapshotFrame`'s
// `typed_projections` sidecar (ADR-0037) under the SAME key. A host with a
// `KRDG` decoder prefers this typed payload; an un-updated host falls back to
// the generic `Value` subtree. Purely additive (Wave C).
//
// ## Timestamp fields (aim.md §62 compliance)
//
// Timestamp fields (`last_connected_ms`, `last_event_ms`, `opened_ms`,
// `eose_ms`) carry Unix epoch milliseconds (ulong). Shells format them as
// "Xs ago" at render time using platform helpers (`relativeTimeFromUnixSeconds`
// on iOS, `formatRelativeTime` on Android). The projection builder no longer
// calls `format_ago_*` or reads `now` per-row; the snapshot bytes are stable
// across 4 Hz ticks when relay state has not changed.
//
// ## Capture-once ownership
//
// The JSON path captures the produced `RelayDiagnosticsSnapshot` ONCE into a
// per-tick `Kernel` field; the typed path maps that single captured STRUCT
// (field-for-field, the #1031 convention). This built-in is UNCONDITIONAL —
// its JSON key is always present, so its typed entry is always pushed too.
//
// Field-for-field mirror of the SERIALISED structs. The `Option<String>` fields
// carry NO serde `skip_serializing_if`, so they serialise as JSON
// `null`-when-`None` (key always present); the typed buffer carries each presence
// as an explicit `has_*` flag.
//
// D0: a relay-diagnostics roll-up is generic transport telemetry — relay
// connection / auth / role state, subscription counts, byte/event counters, and
// pre-formatted display strings. No protocol-specific (NIP-NN) semantics. Generic
// framework transport-diagnostics view, so kernel-owned and typed here. D6: the
// decoder returns `Err(String)` on malformed input, never panics.
//
// Regenerate the checked-in Rust bindings only with the workspace FlatBuffers
// pin (25.12.19), enforced by ci/check-flatbuffers-version-pins.sh:
//   flatc --rust -o crates/nmp-core/src/kernel/typed_projections/generated \
//         crates/nmp-core/schema/relay_diagnostics.fbs

// Enriched per-wire-subscription detail row (mirror of `RelayDiagnosticsWireSub`).
table RelayDiagnosticsWireSub {
  // Full wire id (hex) — stable list identity.
  wire_id:string;
  // Pre-formatted short id (`"abcd1234…"`).
  short_wire_id:string;
  // Owning relay URL.
  relay_url:string;
  // Filter prose, propagated unchanged from `WireSub.filter_summary`.
  filter_summary:string;
  // Pre-formatted state label (`"Open"` / `"Pending"` / `"Closed"` / …).
  state_label:string;
  // Semantic state hue (`"ok"` / `"warn"` / `"muted"` / `"error"`).
  state_tone:string;
  // Pre-formatted consumer-count label (`"1 consumer"` / …); empty when zero.
  consumer_count_label:string;
  // Pre-formatted events received (compact); `has_events_rx_display == false`
  // mirrors JSON `null` (zero events).
  has_events_rx_display:bool;
  events_rx_display:string;
  // True iff EOSE has been observed.
  eose_observed:bool;
  // Unix epoch milliseconds when the subscription opened. Shells format as
  // "Xs ago" at render time (aim.md §62).
  opened_ms:ulong;
  // Unix epoch milliseconds of the last event received; 0 when none.
  last_event_ms:ulong;
  // Unix epoch milliseconds when EOSE was observed; 0 when none.
  eose_ms:ulong;
  // Close reason prose; absent when still open.
  has_close_reason:bool;
  close_reason:string;
}

// ADR-0051 — relay-information document (NIP-11), mirror of
// `RelayDiagnosticsInfo`. Carried as an OPTIONAL child table on
// `RelayDiagnosticsRow.info`: a null table means "no document fetched yet"
// (the JSON `info: null` case), so no `has_info` flag is needed — table
// presence is the discriminator. Each `Option<String>` field carries its
// presence as an explicit `has_*` flag; `supported_nips` is a (possibly
// empty) list; the three `limitation` flags carry both a `has_*` presence
// bit and the bool value.
table RelayDiagnosticsInfo {
  has_name:bool;
  name:string;
  has_description:bool;
  description:string;
  has_icon:bool;
  icon:string;
  has_pubkey:bool;
  pubkey:string;
  has_contact:bool;
  contact:string;
  has_software:bool;
  software:string;
  has_version:bool;
  version:string;
  supported_nips:[uint];
  has_payment_required:bool;
  payment_required:bool;
  has_auth_required:bool;
  auth_required:bool;
  has_restricted_writes:bool;
  restricted_writes:bool;
}

// One rolled-up row per known relay URL (mirror of `RelayDiagnosticsRow`).
table RelayDiagnosticsRow {
  // Canonical relay URL — stable list identity.
  relay_url:string;
  // Pre-formatted short URL.
  short_url:string;
  // Display label for the relay's role (`"Content"` / `"Indexer"` / …).
  role_label:string;
  // Semantic role hue (`"primary"` / `"write"` / `"accent"` / `"secondary"`).
  role_tone:string;
  // Pre-formatted connection label (`"Connected"` / `"Reconnecting"` / …).
  connection_label:string;
  // Semantic connection hue (`"ok"` / `"warn"` / `"error"` / `"muted"`).
  connection_tone:string;
  // Pre-formatted auth label (`"OK"` / `"Pending"` / `"Required"` / `"—"`).
  auth_label:string;
  // Semantic auth hue (`"ok"` / `"warn"` / `"muted"`).
  auth_tone:string;
  // Total wire subscriptions known to this relay.
  total_sub_count:uint;
  // Wire subscriptions in an active state.
  active_sub_count:uint;
  // Wire subscriptions that have observed EOSE.
  eosed_sub_count:uint;
  // Session EVENT frames received on this relay URL.
  total_events_rx:ulong;
  // Pre-formatted total events (compact: `"1.2K"` / `"34"`).
  total_events_display:string;
  // Reconnect attempts since process start.
  reconnect_count:uint;
  // Pre-formatted bytes-received label; absent when the counter is zero.
  has_bytes_rx_display:bool;
  bytes_rx_display:string;
  // Pre-formatted bytes-transmitted label; absent when zero.
  has_bytes_tx_display:bool;
  bytes_tx_display:string;
  // Unix epoch milliseconds of the last successful connect; 0 when the relay
  // has never connected. Shells format as "Xs ago" at render time (aim.md §62).
  last_connected_ms:ulong;
  // Unix epoch milliseconds of the last event received; 0 when none.
  last_event_ms:ulong;
  // Most recent NIP-01 NOTICE prose; absent when none.
  has_last_notice:bool;
  last_notice:string;
  // Most recent error prose; absent when none.
  has_last_error:bool;
  last_error:string;
  // Per-wire-subscription detail rows (kernel-sorted by `wire_id`).
  wire_subs:[RelayDiagnosticsWireSub];
  // ADR-0051 — the relay's NIP-11 information document; null until
  // `nmp-nip11` has fetched it (or the relay serves no document).
  info:RelayDiagnosticsInfo;
}

// Enriched logical-interest row (mirror of `RelayDiagnosticsInterest`).
table RelayDiagnosticsInterest {
  key:string;
  state:string;
  // Semantic state hue (`"ok"` / `"warn"` / `"muted"`).
  state_tone:string;
  refcount:uint;
  cache_coverage:string;
  relay_urls:[string];
}

// Top-level diagnostics snapshot (mirror of `RelayDiagnosticsSnapshot`).
table RelayDiagnosticsSnapshot {
  // One row per known relay URL (kernel-ordered: typed lanes then outbox-only).
  relays:[RelayDiagnosticsRow];
  // Pre-rolled logical-interest rows.
  interests:[RelayDiagnosticsInterest];
}

file_identifier "KRDG";
root_type RelayDiagnosticsSnapshot;
