namespace nmp.kernel;

// Typed FlatBuffers wire for the kernel-owned `action_stages` snapshot
// projection (Tier-2: kernel built-in).
//
// The producer is `Kernel::snapshot_projections_with_publish_cluster` in
// `crates/nmp-core/src/kernel/update/projections.rs`, which reads
// `action_stages_projection()` (a `serde_json::Value` object keyed by
// `correlation_id`: each value is an ARRAY of stage rows
// `{stage, reason?, at_ms, detail?}` — the per-id lifecycle history) and inserts
// it under the JSON key `"action_stages"` ONLY when the accessor returned a
// non-null value. That generic `Value` projection stays the source of truth
// (inserted unchanged); this buffer is emitted ALONGSIDE it in the
// `SnapshotFrame`'s `typed_projections` sidecar (ADR-0037) under the SAME key. A
// host with a `KAST` decoder prefers this typed payload; an un-updated host
// falls back to the generic `Value` subtree. Purely additive (Wave C).
//
// ## Capture-once ownership
//
// `action_stages_projection()` is a `&self` COPY (not a drain), but
// `take_action_results_projection()` RECORDS terminals into this same mirror
// earlier in the tick, so its contents change across the tick. To stay strictly
// uniform with the four genuinely-drained built-ins — and to read the EXACT
// value the JSON key carries — the JSON path captures this projection's `Value`
// ONCE into a per-tick `Kernel` field; the typed path reads that captured
// `Value` and builds this buffer by PARSING it. The typed entry is pushed
// EXACTLY when the JSON key is present, and is ABSENT in steady state (no id
// tracked -> nothing captured). Necessary deviation from the #1031 DTO->Model
// convention: the accessor exposes only `serde_json::Value`.
//
// FlatBuffers has no map type, so the `correlation_id -> [stage]` map is
// flattened to a vector of `{key, stages}` entries SORTED BY KEY. The serde JSON
// map is BTree-ordered, so sorting the entries by key keeps the typed and JSON
// orderings identical. The inner history arrays preserve producer order.
//
// `stage` is the closed snake_case vocabulary string (`"requested"` /
// `"awaiting_capability"` / `"publishing"` / `"accepted"` / `"failed"`). The
// `failed` variant lifts a `reason` sibling (flattened serde enum); it is
// carried with a `has_reason` flag (present only for `failed`). `at_ms` is the
// kernel-clock record timestamp. `detail` is opaque per-stage JSON
// (`skip_serializing_if = Option::is_none`); carried as the SERIALISED JSON
// string with a `has_detail` presence flag (nmp-core forwards, never interprets).
//
// D0: a stage row carries a correlation id, a generic lifecycle stage string, a
// timestamp, an optional reason, and an opaque detail body — no protocol-specific
// (NIP-NN) semantics. Generic framework action-lifecycle mirror, so kernel-owned
// and typed here. D6: the decoder returns `Err(String)` on malformed input,
// never panics.
//
// Regenerate the checked-in Rust bindings only with the workspace FlatBuffers
// pin (25.12.19), enforced by ci/check-flatbuffers-version-pins.sh:
//   flatc --rust -o crates/nmp-core/src/kernel/typed_projections/generated \
//         crates/nmp-core/schema/action_stages.fbs

// Field-for-field mirror of one SERIALISED `StageEntry` row.
table ActionStageEntry {
  // Closed snake_case stage string (`"requested"` / `"awaiting_capability"` /
  // `"publishing"` / `"accepted"` / `"failed"`).
  stage:string;
  // `Failed { reason }`'s reason, lifted as a sibling of `stage`; present only
  // when `stage == "failed"`.
  has_reason:bool;
  reason:string;
  // Kernel-clock record timestamp (unix millis).
  at_ms:ulong;
  // Opaque per-stage detail (relay url, error class, …) carried as the
  // SERIALISED JSON string; `has_detail == false` mirrors the omitted JSON key.
  has_detail:bool;
  detail:string;
}

// One `correlation_id -> [ActionStageEntry]` map entry. Entries are sorted by
// `key`; the inner `stages` array preserves producer (history) order.
table ActionStagesEntry {
  // The map key — the action's correlation id.
  key:string;
  stages:[ActionStageEntry];
}

table ActionStagesSnapshot {
  entries:[ActionStagesEntry];
}

file_identifier "KAST";
root_type ActionStagesSnapshot;
