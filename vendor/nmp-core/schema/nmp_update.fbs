namespace nmp.transport;

// Runtime pins are intentionally asymmetric until every platform package
// manager publishes the same FlatBuffers line:
// - Rust + Swift: 25.12.19
// - Web/TypeScript: 25.9.23
// - Android/Kotlin runtime: 25.2.10
// Regenerate checked-in bindings only with the matching runtime guard for that
// platform; ci/check-flatbuffers-version-pins.sh enforces the current set.

enum FrameKind:ubyte {
  Snapshot = 0,
  Panic = 1
}

// ADR-0055 Rung 2 — per-projection presence state stamped on the wire.
//
// Wire contract (ADR-0055 D1/D3):
//   Changed (0) — rev advanced since last host apply; payload PRESENT this tick.
//   Cleared (1) — projection went absent this tick (drain emptied, view closed);
//                 payload omitted; host MUST drop its cached value explicitly.
//   Unchanged   — represented by ABSENCE of the TypedProjection entry (Rung-3
//                 concept). In Rung 2 all projections are still emitted every
//                 tick, so only Changed appears in practice. The enum is defined
//                 now so no schema change is needed when Rung 3 omits entries.
//
// Default = Changed so an old reader (pre-Rung-2) that does not decode this
// field treats every emitted entry as a payload update — correct behavior.
enum ProjectionPresenceState:ubyte {
  Changed = 0,
  Cleared = 1
}

enum ValueKind:ubyte {
  Null = 0,
  Bool = 1,
  Int = 2,
  UInt = 3,
  Float = 4,
  String = 5,
  List = 6,
  Map = 7
}

table Pair {
  key:string (required);
  value:Value;
}

table Value {
  kind:ValueKind = Null;
  bool_value:bool = false;
  int_value:long = 0;
  uint_value:ulong = 0;
  float_value:double = 0.0;
  string_value:string;
  list:[Value];
  map:[Pair];
}

table TypedPayload {
  schema_id:string;
  schema_version:uint = 1;
  file_identifier:string;
  payload:[ubyte];
}

table TypedProjection {
  key:string;
  payload:TypedPayload;
  // ADR-0055 Rung 2 — APPENDED at the tail (new vtable slots) so old readers
  // that do not know these fields ignore them and still decode key+payload
  // correctly (FlatBuffers backward-safety: tail-appended fields read as their
  // default on an older reader).
  //
  // projection_rev: monotonic u64 for this key derived by the kernel's
  // ProjectionRevTracker (SUM of source-version counters across the key's
  // declared dependencies). Resets to 0 on session_id / snapshot_epoch change.
  // The host keys its decoded-value cache on (key, projection_rev) and skips
  // re-decode when the rev is unchanged (Rung-3 apply logic; Rung 2 stores
  // but does not yet act on this field).
  projection_rev:ulong;                    // ADR-0055 Rung 2: per-key monotonic rev
  // state: presence classification for this tick. Default = Changed (0) so
  // pre-Rung-2 readers treat every emitted projection as a payload update.
  state:ProjectionPresenceState = Changed; // ADR-0055 Rung 2: Changed|Cleared
}

// ADR-0044 Tier-3 nested tables. Each mirrors the framework-owned `nmp-core`
// struct of the same name field-for-field, in Rust declaration order
// (crates/nmp-core/src/kernel/types.rs). All values raw per ADR-0032
// (hex pubkeys, ms/unix-seconds, raw counts) — typing is a transport
// optimization, not a license to pre-format. Rust `usize`/`u128` counters map
// to `ulong` for platform-width independence; `Option<u128>`/`Option<bool>`
// map to native-optional scalars (`= null`); `Option<String>` maps to a string
// field that is simply absent when `None`. Append new fields at the TAIL only.

// Mirrors nmp_core::kernel::types::Metrics (types.rs:729).
table Metrics {
  generated_events:ulong;
  note_events:ulong;
  profile_events:ulong;
  duplicate_events:ulong;
  delete_events:ulong;
  stored_events:ulong;                    // usize -> ulong
  tombstones:ulong;                       // usize -> ulong
  visible_items:ulong;                    // usize -> ulong
  visible_profiled_items:ulong;           // usize -> ulong
  visible_placeholder_avatar_items:ulong; // usize -> ulong
  open_views:uint;
  events_since_last_update:ulong;
  diagnostic_firehose_events:ulong;
  inserted_count:ulong;                   // usize -> ulong
  updated_count:ulong;                    // usize -> ulong
  removed_count:ulong;                    // usize -> ulong
  events_per_second_configured:uint;
  emit_hz_configured:uint;
  update_sequence:ulong;
  estimated_store_bytes:ulong;            // usize -> ulong
  payload_bytes:ulong;                    // usize -> ulong
  store_to_payload_ratio:double;
  actor_queue_depth:uint;
  frames_rx:ulong;
  events_rx:ulong;
  eose_rx:ulong;
  notices_rx:ulong;
  closed_rx:ulong;
  bytes_rx:ulong;
  bytes_tx:ulong;
  contacts_authors:ulong;                 // usize -> ulong
  timeline_authors:ulong;                 // usize -> ulong
  first_event_ms:ulong = null;            // Option<u128> -> native-optional
  target_profile_loaded_ms:ulong = null;
  timeline_opened_ms:ulong = null;
  timeline_first_item_ms:ulong = null;
  update_emitted_ms:ulong = null;
  last_event_to_emit_ms:ulong = null;
  max_event_to_emit_ms:ulong;             // u128 -> ulong
  max_events_per_update:ulong;
  dispatch_drops_total:ulong;
  claim_drops_total:ulong;
  make_update_us:ulong;                   // u128 -> ulong
  serialize_us:ulong;                     // u128 -> ulong
  update_frame_degradations_total:ulong;
}

// Mirrors nmp_core::kernel::types::RelayStatus (types.rs:324).
table RelayStatus {
  role:string;
  relay_url:string;
  connection:string;
  auth:string;
  negentropy_probe:string;
  active_wire_subscriptions:ulong;        // usize -> ulong
  reconnect_count:uint;
  last_connected_at_ms:ulong = null;      // Option<u128> -> native-optional
  last_event_at_ms:ulong = null;
  last_notice:string;                     // Option<String> -> absent = null
  last_error:string;
  error_category:string;
  events_rx:ulong;
  bytes_rx:ulong;
  bytes_tx:ulong;
  denied:bool = false;
  last_close_reason:string;
}

// Mirrors nmp_core::kernel::types::LogicalInterestStatus (types.rs:377).
table LogicalInterestStatus {
  key:string;
  state:string;
  refcount:uint;
  relay_urls:[string];
  cache_coverage:string;
  warming_until_ms:ulong = null;          // Option<u128> -> native-optional
}

// Mirrors nmp_core::kernel::types::WireSubscriptionStatus (types.rs:360).
table WireSubscriptionStatus {
  wire_id:string;
  relay_url:string;
  filter_summary:string;
  state:string;
  logical_consumer_count:uint;
  events_rx:ulong;
  opened_at_ms:ulong;                     // u128 -> ulong
  last_event_at_ms:ulong = null;          // Option<u128> -> native-optional
  eose_at_ms:ulong = null;
  close_reason:string;                    // Option<String> -> absent = null
}

table SnapshotFrame {
  schema_version:uint = 1;
  // PR-B (#991/#979): DEPRECATED — emission zeroed, no reader remains.
  // Every kernel-built-in projection has a typed codec emitted each tick
  // (accounts/active_account/profile/configured_relays/settings_hub/
  // publish_outbox/outbox_summary/author_view/thread_view/resolved_profiles/
  // claimed_events in kernel/typed_projections/; relay_statuses + metrics are
  // ADR-0044 Tier-3 envelope fields). All Rust shells (chirp-tui,
  // chirp-desktop, nmp-gallery TUI + desktop), iOS, and Android read
  // typed-first. The field is kept `(deprecated)` so the vtable slot stays
  // reserved: pre-PR-B frames (e.g. the v1 golden fixture) remain parseable,
  // and no future field can be assigned this slot. Generated bindings expose
  // no accessor for it; web/chirp's typed-first port is post-v1 (#1209).
  payload:Value (deprecated);             // PR-B: zeroed — typed sidecars are authoritative
  typed_projections:[TypedProjection];    // new: typed sidecar

  // ADR-0044 Tier-3 envelope fields. APPENDED at the tail so existing
  // payload-readers stay byte-compatible (FlatBuffers keys fields by vtable
  // slot; new trailing fields read as default/absent on an old reader).
  // Mirrors the top-level KernelSnapshot fields (types.rs:799).
  rev:ulong;                              // identity / revision
  kernel_schema_version:uint;             // KERNEL_SCHEMA_VERSION (distinct from
                                          // the transport schema_version above)
  last_tick_ms:ulong;                     // timing / actor-liveness (ADR-0028)
  update_kind:string;                     // run-state ("ViewBatch")
  running:bool = false;
  metrics:Metrics;
  relay_status:RelayStatus;               // aggregate connection summary
  relay_statuses:[RelayStatus];           // per-relay vector (keyed by relay_url)
  logical_interests:[LogicalInterestStatus];
  wire_subscriptions:[WireSubscriptionStatus];
  logs:[string];
  last_error_toast:string;                // Option<String> -> absent = null
  last_error_category:string;
  last_planner_error:string;
  store_open_failure:string;
  no_configured_relays:bool = null;       // Option<bool> -> native-optional
  negentropy_sync_stats:NegentropySyncStats; // GAP-5: absent = zero/pre-first-session

  // ADR-0055 Rung 2 — frame-level epoch identity. APPENDED at the tail so
  // existing readers ignore them (FlatBuffers backward-safety). Spec: D4.
  //
  // session_id: kernel-start wall-clock stamp (TimingMilestones::started_unix_ms).
  // Differs across process restarts. When the host sees a changed session_id it
  // MUST discard all per-key applied-rev state and re-baseline (D4). Default 0
  // on old writers (pre-Rung-2) — any value that differs across restarts
  // suffices; 0 is a safe sentinel (host treats a 0→N transition as a restart).
  snapshot_epoch:ulong;                    // ADR-0055 Rung 2: within-session monotonic epoch
  // snapshot_epoch: within-session monotonic counter, bumped on any event that
  // invalidates the host's entire cached projection set without a process restart:
  // account-switch, KERNEL_SCHEMA_VERSION change, explicit resync request (D5).
  // On bump → next frame is a full baseline (all projections -> Changed, Rung 3).
  session_id:ulong;                        // ADR-0055 Rung 2: kernel-start wall-clock ms
}

// GAP-5: Mirrors nmp_core::kernel::types::NegentropySyncStats.
// Absent on the wire when the kernel is at default (no session has completed).
// All fields default to 0; last_reconcile_at_ms defaults to null (Option<u64>).
table NegentropySyncStats {
  rounds:ulong;
  have_ids:ulong;
  need_ids:ulong;
  local_item_count:ulong;
  transfer_avoided_bytes:ulong;
  last_reconcile_at_ms:ulong = null;    // Option<u64> -> native-optional
}

table PanicFrame {
  msg:string (required);
}

table UpdateFrame {
  kind:FrameKind = Snapshot;
  snapshot:SnapshotFrame;
  panic:PanicFrame;
}

root_type UpdateFrame;
file_identifier "NMPU";
